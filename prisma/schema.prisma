generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Building {
  id            Int             @id @default(autoincrement())
  name          String
  code          String          @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  Reimbursement Reimbursement[]
  Settings      Settings?
  Transaction   Transaction[]
}

model Category {
  id          Int           @id @default(autoincrement())
  name        String
  type        CategoryType
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  Transaction Transaction[]
}

model Employee {
  id                         Int                          @id @default(autoincrement())
  firstName                  String
  lastName                   String
  nickname                   String?
  position                   Position
  salary                     Decimal                      @default(0) @db.Decimal(15, 2)
  isActive                   Boolean                      @default(true)
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime
  SocialSecurityContribution SocialSecurityContribution[]
}

model ExpenseHistory {
  id          Int      @id @default(autoincrement())
  targetType  String
  targetId    Int?
  fieldName   String
  fieldLabel  String
  actionType  String
  amount      Decimal  @db.Decimal(15, 2)
  description String
  month       Int
  year        Int
  createdAt   DateTime @default(now())

  @@index([targetType, targetId, fieldName, month, year])
}

model GlobalSettings {
  id                           Int      @id @default(autoincrement())
  maxCareExpense               Decimal  @default(0) @db.Decimal(15, 2)
  trafficCareExpense           Decimal  @default(0) @db.Decimal(15, 2)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime
  amenityExpense               Decimal  @default(0) @db.Decimal(15, 2)
  coffeeExpense                Decimal  @default(0) @db.Decimal(15, 2)
  cookieExpense                Decimal  @default(0) @db.Decimal(15, 2)
  fuelExpense                  Decimal  @default(0) @db.Decimal(15, 2)
  maidTravelExpense            Decimal  @default(0) @db.Decimal(15, 2)
  motorcycleMaintenanceExpense Decimal  @default(0) @db.Decimal(15, 2)
  parkingExpense               Decimal  @default(0) @db.Decimal(15, 2)
  waterBottleExpense           Decimal  @default(0) @db.Decimal(15, 2)
  shippingExpense              Decimal  @default(0) @db.Decimal(15, 2)
  cleaningSupplyExpense        Decimal  @default(0) @db.Decimal(15, 2)
  laundryDetergentExpense      Decimal  @default(0) @db.Decimal(15, 2)
  foodExpense                  Decimal  @default(0) @db.Decimal(15, 2)
  coffeeMateExpense            Decimal  @default(0) @db.Decimal(15, 2)
  sugarExpense                 Decimal  @default(0) @db.Decimal(15, 2)
}

model Reimbursement {
  id           Int       @id @default(autoincrement())
  amount       Decimal   @default(0) @db.Decimal(15, 2)
  buildingId   Int
  month        Int
  year         Int
  creditorName String
  description  String?
  paidDate     DateTime?
  isReturned   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  returnedDate DateTime?
  Building     Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId, month, year])
}

model Settings {
  id                        Int      @id @default(autoincrement())
  buildingId                Int      @unique
  managementFeePercent      Decimal  @default(13.5) @db.Decimal(5, 2)
  vatPercent                Decimal  @default(7) @db.Decimal(5, 2)
  monthlyRent               Decimal  @default(0) @db.Decimal(15, 2)
  littleHotelierExpense     Decimal  @default(0) @db.Decimal(15, 2)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime
  cowayWaterFilterExpense   Decimal  @default(0) @db.Decimal(15, 2)
  airportShuttleRentExpense Decimal  @default(0) @db.Decimal(15, 2)
  Building                  Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
}

model SocialSecurityContribution {
  id         Int      @id @default(autoincrement())
  employeeId Int
  amount     Decimal  @default(0) @db.Decimal(15, 2)
  month      Int
  year       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@index([month, year])
}

model Transaction {
  id         Int      @id @default(autoincrement())
  buildingId Int
  categoryId Int
  amount     Decimal  @default(0) @db.Decimal(15, 2)
  month      Int
  year       Int
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  Category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([buildingId, categoryId, month, year])
  @@index([buildingId, month, year])
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  password     String
  name         String
  role         UserRole
  isActive     Boolean  @default(true)
  allowedMenus Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum Position {
  MAID
  MANAGER
  PARTNER
}

enum UserRole {
  PARTNER
  STAFF
  VIEWER
}
