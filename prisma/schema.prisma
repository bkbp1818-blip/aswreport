generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Building {
  id            Int             @id @default(autoincrement())
  name          String
  code          String          @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  reimbursements Reimbursement[]
  rooms         Room[]
  settings      Settings?
  transactions  Transaction[]
}

model Room {
  id             Int              @id @default(autoincrement())
  buildingId     Int
  name           String
  note           String?
  order          Int              @default(0)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  building       Building         @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  expenseHistory ExpenseHistory[]

  @@unique([buildingId, name])
  @@index([buildingId, isActive])
}

model Category {
  id           Int           @id @default(autoincrement())
  name         String
  type         CategoryType
  order        Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Employee {
  id                         Int                          @id @default(autoincrement())
  firstName                  String
  lastName                   String
  nickname                   String?
  position                   Position
  salary                     Decimal                      @default(0) @db.Decimal(15, 2)
  isActive                   Boolean                      @default(true)
  employmentStatus           EmploymentStatus             @default(ACTIVE)
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt
  socialSecurityContributions SocialSecurityContribution[]
  monthlySalaries             MonthlySalary[]
  scheduleTemplates           ScheduleTemplate[]
  scheduleEntries             ScheduleEntry[]
}

model ExpenseHistory {
  id          Int        @id @default(autoincrement())
  targetType  String
  targetId    Int?
  fieldName   String
  fieldLabel  String
  actionType  String
  amount      Decimal    @db.Decimal(15, 2)
  description String
  day         Int?
  month       Int
  year        Int
  createdAt   DateTime   @default(now())
  otaSourceId Int?
  groupId     String?
  roomId      Int?
  userId      Int?
  otaSource   OtaSource? @relation(fields: [otaSourceId], references: [id])
  room        Room?      @relation(fields: [roomId], references: [id], onDelete: SetNull)
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId, fieldName, month, year])
  @@index([otaSourceId])
  @@index([groupId])
  @@index([roomId])
  @@index([userId])
}

model OtaSource {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  order           Int              @default(0)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  expenseHistory  ExpenseHistory[]
}

model GlobalSettings {
  id                           Int      @id @default(autoincrement())
  maxCareExpense               Decimal  @default(0) @db.Decimal(15, 2)
  trafficCareExpense           Decimal  @default(0) @db.Decimal(15, 2)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  amenityExpense               Decimal  @default(0) @db.Decimal(15, 2)
  coffeeExpense                Decimal  @default(0) @db.Decimal(15, 2)
  cookieExpense                Decimal  @default(0) @db.Decimal(15, 2)
  fuelExpense                  Decimal  @default(0) @db.Decimal(15, 2)
  maidTravelExpense            Decimal  @default(0) @db.Decimal(15, 2)
  motorcycleMaintenanceExpense Decimal  @default(0) @db.Decimal(15, 2)
  parkingExpense               Decimal  @default(0) @db.Decimal(15, 2)
  waterBottleExpense           Decimal  @default(0) @db.Decimal(15, 2)
  shippingExpense              Decimal  @default(0) @db.Decimal(15, 2)
  cleaningSupplyExpense        Decimal  @default(0) @db.Decimal(15, 2)
  laundryDetergentExpense      Decimal  @default(0) @db.Decimal(15, 2)
  foodExpense                  Decimal  @default(0) @db.Decimal(15, 2)
  coffeeMateExpense            Decimal  @default(0) @db.Decimal(15, 2)
  sugarExpense                 Decimal  @default(0) @db.Decimal(15, 2)
}

model Reimbursement {
  id           Int       @id @default(autoincrement())
  amount       Decimal   @default(0) @db.Decimal(15, 2)
  buildingId   Int
  month        Int
  year         Int
  creditorName String
  description  String?
  paidDate     DateTime?
  isReturned   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  returnedDate DateTime?
  building     Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId, month, year])
}

model Settings {
  id                        Int      @id @default(autoincrement())
  buildingId                Int      @unique
  managementFeePercent      Decimal  @default(13.5) @db.Decimal(5, 2)
  vatPercent                Decimal  @default(7) @db.Decimal(5, 2)
  monthlyRent               Decimal  @default(0) @db.Decimal(15, 2)
  littleHotelierExpense     Decimal  @default(0) @db.Decimal(15, 2)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  cowayWaterFilterExpense   Decimal  @default(0) @db.Decimal(15, 2)
  airportShuttleRentExpense Decimal  @default(0) @db.Decimal(15, 2)
  building                  Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
}

model SocialSecurityContribution {
  id         Int      @id @default(autoincrement())
  employeeId Int
  amount     Decimal  @default(0) @db.Decimal(15, 2)
  month      Int
  year       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@index([month, year])
}

model MonthlySalary {
  id         Int      @id @default(autoincrement())
  employeeId Int
  salary     Decimal  @default(0) @db.Decimal(15, 2)
  isPaused   Boolean  @default(false) // true = ปิด/ลาออกเดือนนี้ (ไม่นับรวม), false = ทำงานปกติ (ยอดเป็น 0 ได้)
  month      Int
  year       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@index([month, year])
}

// ── ตารางเวลางานพนักงาน (Staff Schedule) — ฟีเจอร์ display/วางแผน แยกจากระบบการเงินทั้งหมด ──

// แม่แบบกะประจำต่อพนักงานต่อวันในสัปดาห์ (weekday 0=จันทร์ ... 6=อาทิตย์)
// หนึ่งคนมีได้ 7 แถว = กะมาตรฐานที่ระบบเอาไปเติมทุกสัปดาห์
model ScheduleTemplate {
  id         Int      @id @default(autoincrement())
  employeeId Int
  weekday    Int // 0=จันทร์, 1=อังคาร, ..., 6=อาทิตย์
  startTime  String? // รูปแบบ "HH:mm" เช่น "09:00" (null ได้ถ้าเป็นวันหยุด)
  endTime    String? // รูปแบบ "HH:mm" เช่น "18:00"
  isDayOff   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, weekday])
  @@index([employeeId])
}

// กะจริงรายวัน (ใช้ override แม่แบบเฉพาะวันที่ปรับ)
// ถ้าไม่มีแถวสำหรับวันนั้น → ใช้ค่าจาก ScheduleTemplate ของ weekday นั้น
// เก็บเฉพาะวันที่ >= 2026-07-01 (บังคับที่ server ด้วย)
model ScheduleEntry {
  id         Int      @id @default(autoincrement())
  employeeId Int
  date       DateTime @db.Date
  startTime  String? // รูปแบบ "HH:mm" (null ได้ถ้าเป็นวันหยุด)
  endTime    String? // รูปแบบ "HH:mm"
  isDayOff   Boolean  @default(false)
  note       String? // เช่น PT / วันหยุดนักขัตฤกษ์
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

model Transaction {
  id         Int      @id @default(autoincrement())
  buildingId Int
  categoryId Int
  amount     Decimal  @default(0) @db.Decimal(15, 2)
  month      Int
  year       Int
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([buildingId, categoryId, month, year])
  @@index([buildingId, month, year])
}

model User {
  id             Int              @id @default(autoincrement())
  username       String           @unique
  password       String
  name           String
  role           UserRole
  isActive       Boolean          @default(true)
  allowedMenus   Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  expenseHistory ExpenseHistory[]
}

model Holiday {
  id        Int      @id @default(autoincrement())
  name      String
  date      DateTime @db.Date
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
  @@index([date])
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum Position {
  MAID
  MANAGER
  PARTNER
}

enum UserRole {
  PARTNER
  STAFF
  VIEWER
}

// สถานะพนักงาน (ป้ายถาวรระดับตัวคน) — คุม isPaused รายเดือนเบื้องหลัง ไม่แตะสูตรคำนวณเดิม
// ACTIVE = ทำงานอยู่ (isPaused=false), RESIGNED = ลาออกแล้ว (isPaused=true), OUTSOURCE = จ่ายตามจริง (isPaused=false)
enum EmploymentStatus {
  ACTIVE
  RESIGNED
  OUTSOURCE
}
